# Public domain
DOMAIN=shop.minseok91.cloud

# Host ports (bound to loopback; exposed via nginx reverse proxy)
STOREFRONT_HOST_PORT=3300
API_HOST_PORT=38080
DB_HOST_PORT=5433

# Postgres
POSTGRES_DB=vibeshop
POSTGRES_USER=vibeshop
POSTGRES_PASSWORD=CHANGE_ME

# API runtime
APP_PORT=8080
DB_HOST=postgres
DB_PORT=5432
DB_NAME=vibeshop
DB_USERNAME=vibeshop
DB_PASSWORD=CHANGE_ME
CORS_ALLOWED_ORIGINS=https://shop.minseok91.cloud
APP_SESSION_COOKIE_SECURE=true
APP_SESSION_COOKIE_SAME_SITE=Lax
APP_DEMO_SEED_ENABLED=false
# This repository ships only a mock gateway. Use demo mode until a real gateway adapter is installed.
APP_RUNTIME_MODE=demo
APP_PAYMENT_MOCK_ENABLED=true
NEXT_PUBLIC_DEMO_MODE=true
APP_DEMO_ADMIN_EMAIL=admin@vibeshop.local
APP_DEMO_ADMIN_PASSWORD=CHANGE_ME
MANAGEMENT_HEALTH_SHOW_DETAILS=never
