{
  "name": "vibe-shop",
  "private": true,
  "scripts": {
    "dev:storefront": "npm --prefix apps/storefront run dev",
    "dev:api": "apps\\api\\gradlew.bat bootRun",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:storefront\"",
    "lint:storefront": "npm --prefix apps/storefront run lint",
    "build:storefront": "npm --prefix apps/storefront run build",
    "build:api": "cd apps/api && gradlew.bat build",
    "test:api": "cd apps/api && gradlew.bat test",
    "qa:e2e": "node tests/e2e/mvp-smoke.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2"
  }
}
