{
  "name": "vibe-shop",
  "private": true,
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "infra:up": "docker compose up -d postgres",
    "infra:down": "docker compose down",
    "dev:storefront": "node scripts/run-storefront-tool.mjs next dev --hostname 127.0.0.1 --port 3000",
    "dev:api": "node scripts/run-api-gradle.mjs bootRun",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:storefront\"",
    "lint:storefront": "node scripts/run-storefront-tool.mjs eslint .",
    "build:storefront": "node scripts/run-storefront-tool.mjs next build",
    "build:api": "node scripts/run-api-gradle.mjs build",
    "test:api": "node scripts/run-api-gradle.mjs test",
    "qa:e2e": "node scripts/ensure-postgres.mjs && node node_modules/playwright/cli.js test",
    "qa:e2e:headed": "node scripts/ensure-postgres.mjs && node node_modules/playwright/cli.js test --headed",
    "qa:e2e:ui": "node scripts/ensure-postgres.mjs && node node_modules/playwright/cli.js test --ui",
    "qa:e2e:install": "node node_modules/playwright/cli.js install chromium"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2"
  }
}
